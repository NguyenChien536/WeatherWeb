# ===========================================
# WeatherNow — Environment Variables
# ===========================================
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control!

# OpenWeatherMap One Call 3.0
# Get your key at: https://openweathermap.org/api/one-call-3
REACT_APP_OPENWEATHER_API_KEY=your_openweather_api_key_here

# WeatherAPI.com (for UV, AQI, Search Suggestions)
# Get your key at: https://www.weatherapi.com/
REACT_APP_WEATHER_API_KEY=your_weatherapi_key_here

# Windy API v2 (for interactive map & wind forecast)
# Get your key at: https://api.windy.com/
REACT_APP_WINDY_API_KEY=your_windy_api_key_here
